# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template des variables d'environnement
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT : Copier ce fichier en .env et remplir les valeurs.
#             Ne JAMAIS committer le .env réel (voir .gitignore).
#
# En production, utiliser des secrets managés :
#   - GitHub Actions Secrets (pour le CI/CD)
#   - HashiCorp Vault, AWS Secrets Manager, GCP Secret Manager
#   - Docker Swarm secrets ou Kubernetes Secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Observa API
APP_VERSION=1.0.0
DEBUG=false

# Clé secrète : générer avec `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=CHANGEME_generate_a_secure_random_key_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=observa
POSTGRES_USER=observa_user
# Générer avec : openssl rand -base64 24
POSTGRES_PASSWORD=CHANGEME_strong_postgres_password

# ── Redis ─────────────────────────────────────────────────────────────────────
# Laisser vide pour Redis sans auth (dev local uniquement)
REDIS_PASSWORD=CHANGEME_strong_redis_password

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGEME_strong_grafana_password

# ── Docker Registry ───────────────────────────────────────────────────────────
REGISTRY=ghcr.io/yourusername
IMAGE_TAG=latest

# ── Métriques ─────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
